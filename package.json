{
  "name": "wisp",
  "version": "1.0.0",
  "description": "Wisp desktop filesystem organizer",
  "main": "backend/main.cjs",
  "scripts": {
    "dev:renderer": "npm --prefix frontend run dev",
    "build:renderer": "npm --prefix frontend run build",
    "start:electron": "electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:renderer",
    "start": "npm run start:electron"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dipalh/Wisp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/dipalh/Wisp/issues"
  },
  "homepage": "https://github.com/dipalh/Wisp#readme",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.3.1",
    "electron": "^40.6.1",
    "wait-on": "^9.0.4"
  }
}
